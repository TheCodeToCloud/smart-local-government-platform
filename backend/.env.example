# ──────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables — backend/.env.example
#
# Copy this file to backend/.env and fill in real values.
# NEVER commit backend/.env to git — it is already in .gitignore.
#
# Variables marked [REQUIRED] will cause the server to crash if missing.
# Variables marked [OPTIONAL] have safe defaults for local development.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000                                   # [OPTIONAL] Render sets this automatically
NODE_ENV=development                        # [OPTIONAL] Set to 'production' on Render

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] Full MongoDB Atlas connection string. Get it from Atlas → Connect.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# [REQUIRED] Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_or_longer_random_secret_never_use_this_placeholder

# ── Cloudinary (Document Storage) ─────────────────────────────────────────────
# [REQUIRED] Sign in to cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Frontend URL (CORS & QR codes) ────────────────────────────────────────────
# [REQUIRED in production] Full URL of the deployed frontend, no trailing slash.
# Example: https://smart-gov-nepal.onrender.com
FRONTEND_URL=http://localhost:5173

# ── Admin Seed Script (updateAdmin.js) ────────────────────────────────────────
# [OPTIONAL] Only needed when running the admin seeding script manually.
# Never set these in the production server environment — only run the script once.
ADMIN_EMAIL=admin@smartgov.np
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin User
