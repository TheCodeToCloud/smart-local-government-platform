# ──────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables — frontend/.env.example
#
# Copy this file to frontend/.env and fill in real values.
# NEVER commit frontend/.env to git — it is already in .gitignore.
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ────────────────────────────────────────────────────────────
# [REQUIRED in production] Full URL of the deployed backend API, with /api suffix.
# Example: https://smart-gov-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# ── Socket.IO Server URL ───────────────────────────────────────────────────────
# [REQUIRED in production] Full URL of the deployed backend (no /api suffix).
# Used for real-time WebSocket connections.
# Example: https://smart-gov-backend.onrender.com
VITE_SOCKET_URL=http://localhost:5000
